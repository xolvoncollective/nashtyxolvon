# Server Configuration
PORT=3099
NODE_ENV=development

# Database
DATABASE_PATH=./data/nashtypos.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-must-be-at-least-32-characters
JWT_EXPIRES_IN=12h

# CORS Configuration
# Development: Use '*' to allow all origins
# Production: Set to specific frontend URLs (e.g., https://yourdomain.com)
CORS_ORIGIN=*

# Rate Limiting (Production Only)
# In development mode, rate limiting is automatically disabled
# In production mode, rate limit is 100 requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
# Development: DEBUG level with stack traces
# Production: INFO level without stack traces
LOG_LEVEL=INFO

# Future: Supabase (for production cloud deployment)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# Future: Cloudflare (for production deployment)
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token

# Notes:
# - Development mode features: DEBUG logs, CORS from any origin, no rate limiting, stack traces in errors
# - Production mode features: INFO logs, restricted CORS, rate limiting enabled, no stack traces in errors
